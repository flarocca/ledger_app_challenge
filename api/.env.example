# Copy to .env and uncomment what you need to override.
# All values shown are the defaults baked into the API; leaving them unset
# yields identical behavior. The DATABASE_URL at the top is also read by
# sqlx-cli at compile time and by the seed.sh script at runtime.

DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger

# --- SERVER_CONFIG -----------------------------------------------------------
# SERVER_CONFIG__DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger
# SERVER_CONFIG__PORT=4000
# SERVER_CONFIG__CORS_ALLOW_ORIGIN=http://localhost:3000

# --- SESSION_CONFIG ----------------------------------------------------------
# SESSION_CONFIG__COOKIE_NAME=ledger_session
# SESSION_CONFIG__COOKIE_SECURE=false
# SESSION_CONFIG__ROLLING_WINDOW_SECS=86400
# SESSION_CONFIG__ABSOLUTE_SECS=2592000
# SESSION_CONFIG__IDEMPOTENCY_TTL_SECS=600

# --- FEED_CONFIG -------------------------------------------------------------
# FEED_CONFIG__BACKFILL_SIZE=50
# FEED_CONFIG__BROADCAST_CAPACITY=1024

# --- logging -----------------------------------------------------------------
# RUST_LOG=ledger_api=info,sqlx=warn
